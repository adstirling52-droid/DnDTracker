<Window x:Class="DnDTracker.CampaignListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDTracker"
        mc:Ignorable="d"
        Title="Campaign List" Height="450" Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Campaigns"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <ListBox x:Name="CampaignListBox"
         Grid.Row="1"
         Margin="0,0,0,20"
         SelectionChanged="CampaignListBox_SelectionChanged"/>

        <StackPanel Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Center">
            <Button x:Name="OpenCampaignButton"
                    Content="Open Campaign"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="OpenCampaignButton_Click"/>

            <Button x:Name="EditCampaignButton"
                    Content="Edit Campaign"
                    Width="95"
                    Margin="0,0,8,0"
                    Click="EditCampaignButton_Click"/>

            <Button Content="New Campaign"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="NewCampaignButton_Click"/>

            <Button Content="Import Campaign"
                    Width="105"
                    Margin="0,0,8,0"
                    Click="ImportCampaignButton_Click"/>

            <Button x:Name="ExportCampaignButton"
                    Content="Export Campaign"
                    Width="105"
                    Margin="0,0,8,0"
                    Click="ExportCampaignButton_Click"/>

            <Button x:Name="RemoveCampaignButton"
                    Content="Remove Campaign"
                    Width="110"
                    Margin="0,0,8,0"
                    Click="RemoveCampaignButton_Click"/>

            <Button Content="Exit"
                    Width="80"
                    Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
