<Window x:Class="DnDTracker.NewItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDTracker"
        mc:Ignorable="d"
        Title="New Item"
        Height="580"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="WindowHeadingTextBlock"
                   Grid.Row="0"
                   Text="Create New Item"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,25" Grid.RowSpan="2">
            <TextBlock Text="Item Name"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="ItemNameTextBox"
                     Height="28"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Description"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox"
                     Height="28"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Where Found"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="WhereFoundTextBox"
                     Height="28"
                     Margin="0,0,0,12"/>

            <TextBlock Text="When Found"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="WhenFoundTextBox"
                     Height="28"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Current Status"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="CurrentStatusTextBox"
                     Height="28"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Notes"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="NotesTextBox"
                     Height="80"
                     Margin="0,0,0,0"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Save"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="Cancel"
                    Width="80"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>