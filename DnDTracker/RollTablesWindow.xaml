<Window x:Class="DnDTracker.RollTablesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDTracker"
        mc:Ignorable="d"
        Title="Rollable Tables"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Rollable Tables"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="15"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Tables"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <ListBox x:Name="RollTablesListBox"
                             SelectionChanged="RollTablesListBox_SelectionChanged"/>


                    <TextBlock x:Name="NoTablesPlaceholderTextBlock"
                                   Text="No rollable tables imported."
                                   Foreground="Gray"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>
                
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="1"
        BorderBrush="Gray"
        BorderThickness="1"
        Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                   Text="Table Contents"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                    <DataGrid x:Name="RollTableRowsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              Margin="0,0,0,15">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="Black"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Yellow"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="BorderBrush" Value="Goldenrod"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Number"
                            Binding="{Binding Number}"
                            Width="80"/>

                            <DataGridTextColumn Header="Name"
                            Binding="{Binding Name}"
                            Width="160"/>

                            <DataGridTextColumn Header="Physical Description"
                            Binding="{Binding PhysicalDescription}"
                            Width="*"/>

                            <DataGridTextColumn Header="Special Characteristics"
                            Binding="{Binding SpecialCharacteristics}"
                            Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                   Text="Roll Result"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                    <TextBlock x:Name="RolledResultNameTextBlock"
                   Grid.Row="3"
                   Text="No result rolled yet."
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

                    <TextBlock x:Name="RolledResultDescriptionTextBlock"
                   Grid.Row="4"
                   Text=""
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

                    <TextBlock x:Name="RolledResultSpecialTextBlock"
                   Grid.Row="5"
                   Text=""
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

                    <TextBlock x:Name="RolledResultMetaTextBlock"
                   Grid.Row="6"
                   Text=""
                   Foreground="Gray"
                   TextWrapping="Wrap"/>

                    <StackPanel Grid.Row="7"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,12,0,0">
                        <Button x:Name="AddRolledItemToCharacterButton"
            Content="Add to Character"
            Width="120"
            Margin="0,0,10,0"
            Click="AddRolledItemToCharacterButton_Click"/>

                        <Button x:Name="AddRolledItemToUnassignedButton"
            Content="Add to Unassigned"
            Width="130"
            Margin="0,0,10,0"
            Click="AddRolledItemToUnassignedButton_Click"/>

                        <Button x:Name="AddRolledSkillToCharacterButton"
            Content="Add Skill"
            Width="100"
            Click="AddRolledSkillToCharacterButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="ImportCsvButton"
                    Content="Import CSV"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="ImportCsvButton_Click"/>

            <Button x:Name="RemoveTableButton"
                    Content="Remove Table"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="RemoveTableButton_Click"/>

            <Button x:Name="RollButton"
                    Content="Roll"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="RollButton_Click"/>

            <Button Content="Close"
                    Width="90"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
