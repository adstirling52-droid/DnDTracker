<Window x:Class="DnDTracker.CampaignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDTracker"
        mc:Ignorable="d"
        Title="Campaign"
        Height="540"
        Width="1000"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="CampaignNameTextBlock"
                   Grid.Row="0"
                   Text="Campaign Name"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="15"
                    Margin="0,0,10,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <Button Content="Add"
                                Width="50"
                                Margin="0,0,4,0"
                                Click="AddCharacterButton_Click"/>

                        <Button x:Name="EditCharacterButton"
                                Content="Edit"
                                Width="50"
                                Margin="0,0,4,0"
                                Click="EditCharacterButton_Click"/>

                        <Button x:Name="RemoveCharacterButton"
                                Content="Remove"
                                Width="60"
                                Click="RemoveCharacterButton_Click"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Characters"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <StackPanel x:Name="CharacterButtonPanel"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="15"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Items"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <ListBox x:Name="CharacterItemsListBox"
                             Height="250"
                             SelectionChanged="CharacterItemsListBox_SelectionChanged"/>


                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <Button x:Name="AddItemButton"
                                Content="Add Item"
                                Width="80"
                                Margin="0,0,8,0"
                                Click="AddItemButton_Click"/>

                        <Button x:Name="EditItemButton"
                                Content="Edit Item"
                                Width="80"
                                Margin="0,0,8,0"
                                Click="EditItemButton_Click"/>

                        <Button x:Name="RemoveItemButton"
                                Content="Remove Item"
                                Width="95"
                                Click="RemoveItemButton_Click"/>
                    </StackPanel>



                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="Item Provenance"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <TextBlock x:Name="SelectedItemNameTextBlock"
                               Text="Select an item"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="SelectedItemDescriptionTextBlock"
                               Text="Item description will appear here."
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="SelectedItemWhereTextBlock"
                               Text="Where:"
                               Margin="0,0,0,5"/>

                    <TextBlock x:Name="SelectedItemWhenTextBlock"
                               Text="When:"
                               Margin="0,0,0,5"/>

                    <TextBlock x:Name="SelectedItemStatusTextBlock"
                               Text="Current Status:"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Notes:"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>

                    <TextBlock x:Name="SelectedItemNotesTextBlock"
                               Text="Item notes will appear here."
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Close Campaign"
                    Width="120"
                    Click="CloseCampaignButton_Click"/>
        </StackPanel>
    </Grid>
</Window>