<Window x:Class="DnDTracker.CampaignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDTracker"
        mc:Ignorable="d"
        Title="Campaign"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="CampaignNameTextBlock"
                   Grid.Row="0"
                   Text="Campaign Name"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="4.2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="15"
                    Margin="0,0,10,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,15,0,0">
                        <Button Content="Add"
                                Width="50"
                                Margin="0,0,4,0"
                                Click="AddCharacterButton_Click"/>

                        <Button x:Name="EditCharacterButton"
                                Content="Edit"
                                Width="50"
                                Margin="0,0,4,0"
                                Click="EditCharacterButton_Click"/>

                        <Button x:Name="RemoveCharacterButton"
                                Content="Remove"
                                Width="60"
                                Click="RemoveCharacterButton_Click"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Characters"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <StackPanel x:Name="CharacterButtonPanel"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- MIDDLE PANEL -->
            <Border Grid.Column="1"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="15"
                    Margin="0,0,10,0">
                <TabControl x:Name="MiddleTabControl"
                            SelectionChanged="MiddleTabControl_SelectionChanged">

                    <!-- SKILLS TAB -->
                    <TabItem x:Name="SkillsTab"
          Header="Skills">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                    Text="Skills"
                    FontSize="20"
                    FontWeight="Bold"
                    Margin="0,0,0,15"/>

                            <Grid Grid.Row="1">
                                <ListBox x:Name="CharacterSkillsListBox"
                      SelectionChanged="CharacterSkillsListBox_SelectionChanged"/>

                                <TextBlock x:Name="SkillsPlaceholderTextBlock"
                        Text="No skills for this character."
                        Foreground="Gray"
                        FontStyle="Italic"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False"/>
                            </Grid>

                            <StackPanel Grid.Row="2"
                     Orientation="Horizontal"
                     HorizontalAlignment="Center"
                     Margin="0,10,0,0">
                                <Button x:Name="AddSkillButton"
                     Content="Add"
                     Width="60"
                     Margin="0,0,8,0"
                     Click="AddSkillButton_Click"/>

                                <Button x:Name="EditSkillButton"
                     Content="Edit"
                     Width="60"
                     Margin="0,0,8,0"
                     Click="EditSkillButton_Click"/>

                                <Button x:Name="RemoveSkillButton"
                     Content="Remove"
                     Width="75"
                     Click="RemoveSkillButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- ITEMS TAB -->
                    <TabItem x:Name="ItemsTab"
                             Header="Items">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Items"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <ListBox x:Name="CharacterItemsListBox"
                                     Grid.Row="1"
                                     Margin="0,0,0,15"
                                     SelectionChanged="CharacterItemsListBox_SelectionChanged"/>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,10">
                                <Button x:Name="AddItemButton"
                                        Content="Add"
                                        Width="55"
                                        Margin="0,0,6,0"
                                        Click="AddItemButton_Click"/>

                                <Button x:Name="EditItemButton"
                                        Content="Edit"
                                        Width="55"
                                        Margin="0,0,6,0"
                                        Click="EditItemButton_Click"/>

                                <Button x:Name="RemoveItemButton"
                                        Content="Remove"
                                        Width="70"
                                        Margin="0,0,6,0"
                                        Click="RemoveItemButton_Click"/>

                                <Button x:Name="UnassignItemButton"
                                        Content="Unassign"
                                        Width="75"
                                        Click="UnassignItemButton_Click"/>
                            </StackPanel>

                            <Button x:Name="AddProvenanceButton"
                                    Grid.Row="3"
                                    Content="Add Provenance"
                                    Width="130"
                                    HorizontalAlignment="Center"
                                    Click="AddProvenanceButton_Click"/>
                        </Grid>
                    </TabItem>

                   

                    <!-- UNASSIGNED TAB -->
                    <TabItem x:Name="UnassignedTab"
                             Header="Unassigned">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Unassigned Items"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <Grid Grid.Row="1">
                                <ListBox x:Name="UnassignedItemsListBox"
                                         SelectionChanged="UnassignedItemsListBox_SelectionChanged"/>

                                <TextBlock x:Name="UnassignedItemsPlaceholderTextBlock"
                                           Text="No unassigned items."
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,10,0,0">
                                <Button x:Name="AddUnassignedItemButton"
                                        Content="Add"
                                        Width="60"
                                        Margin="0,0,8,0"
                                        Click="AddUnassignedItemButton_Click"/>

                                <Button x:Name="EditUnassignedItemButton"
                                        Content="Edit"
                                        Width="60"
                                        Margin="0,0,8,0"
                                        Click="EditUnassignedItemButton_Click"/>

                                <Button x:Name="RemoveUnassignedItemButton"
                                        Content="Remove"
                                        Width="75"
                                        Margin="0,0,8,0"
                                        Click="RemoveUnassignedItemButton_Click"/>

                                <Button x:Name="AssignUnassignedItemButton"
                                        Content="Assign"
                                        Width="70"
                                        Click="AssignUnassignedItemButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="2"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="DetailsPanelTitleTextBlock"
                               Grid.Row="0"
                               Text="Item Provenance"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <!-- ITEM DETAILS PANEL -->
                    <Grid x:Name="ItemDetailsPanel"
                          Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SelectedItemNameTextBlock"
                                   Grid.Row="0"
                                   Text="Select an item"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Border Grid.Row="1"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                Height="130"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Stretch">
                            <Grid>
                                <Image x:Name="SelectedItemImage"
                                       Stretch="Uniform"
                                       Cursor="Hand"
                                       ToolTip="Double-click to view larger image"
                                       MouseLeftButtonDown="SelectedItemImage_MouseLeftButtonDown"/>

                                <TextBlock x:Name="NoImagePlaceholderTextBlock"
                                           Text="No image selected"
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="SelectedItemDescriptionTextBlock"
                                   Grid.Row="2"
                                   Text="Item description will appear here."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="SelectedItemStatusTextBlock"
                                   Grid.Row="3"
                                   Text="Current Status:"
                                   Margin="0,0,0,10"/>

                        <StackPanel Grid.Row="4"
                                    Margin="0,0,0,12">
                            <TextBlock Text="Latest Note"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>

                            <TextBlock x:Name="LatestItemNotesTextBlock"
                                       Text="Latest item note will appear here."
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5">
                            <TextBlock Text="Provenance History"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <ListBox x:Name="ProvenanceHistoryListBox"
                                     Height="140"
                                     Margin="0,0,0,10"
                                     SelectionChanged="ProvenanceHistoryListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="LightGray"
                                                BorderThickness="1"
                                                Padding="8"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding What}"
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,4"/>

                                                <TextBlock Text="{Binding Where, StringFormat=Where: {0}}"
                                                           Margin="0,0,0,2"/>

                                                <TextBlock Text="{Binding When, StringFormat=When: {0}}"
                                                           Margin="0,0,0,4"/>

                                                <TextBlock Text="{Binding Notes}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Grid.Row="6"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button x:Name="EditProvenanceButton"
                                    Content="Edit Provenance"
                                    Width="110"
                                    Margin="0,0,8,0"
                                    Click="EditProvenanceButton_Click"/>

                            <Button x:Name="DeleteProvenanceButton"
                                    Content="Delete Provenance"
                                    Width="115"
                                    Click="DeleteProvenanceButton_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- SKILL DETAILS PANEL -->
                    <Grid x:Name="SkillDetailsPanel"
                          Grid.Row="1"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SelectedSkillNameTextBlock"
                                   Grid.Row="0"
                                   Text="Select a skill"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <StackPanel Grid.Row="1"
                                    Margin="0,0,0,12">
                            <TextBlock Text="Description"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>

                            <TextBlock x:Name="SelectedSkillDescriptionTextBlock"
                                       Text="Skill description will appear here."
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Notes"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>

                            <TextBlock x:Name="SelectedSkillNotesTextBlock"
                                       Text="Skill notes will appear here."
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Close Campaign"
                    Width="120"
                    Click="CloseCampaignButton_Click"/>
        </StackPanel>
    </Grid>
</Window>