@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 auth-links">
            <a href="/" class="site-home-link">Home</a>
            <div class="auth-links-end">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Hello, @context.User.Identity?.Name</span>
                    <form action="Account/Logout" method="post" class="d-inline">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-link p-0 align-baseline">Log out</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="Account/Register" class="me-3">Register</a>
                    <a href="Account/Login">Log in</a>
                </NotAuthorized>
            </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
