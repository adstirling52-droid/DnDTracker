@page "/"
@attribute [AllowAnonymous]

<PageTitle>Alan's DnD Tracker (Web)</PageTitle>

<h1>Alan's DnD Tracker (Web)</h1>

<AuthorizeView>
    <Authorized>
        <p>Welcome back, @context.User.Identity?.Name.</p>
        <p>You are logged in and ready to track campaigns.</p>
        <p><a href="campaigns">Go to your campaigns</a></p>
    </Authorized>
    <NotAuthorized>
        <p>Please <a href="Account/Login">log in</a> or <a href="Account/Register">register</a> to use DnD Tracker.</p>
    </NotAuthorized>
</AuthorizeView>
