    private async Task SaveItem()
    {
        if (userId is null)
        {
            return;
        }

        var input = BuildItemInput();
        Guid? savedItemId = null;

        if (editingItem)
        {
            savedItemId = itemDialogForUnassigned ? selectedUnassignedItemId!.Value : selectedItemId!.Value;
            var error = await ItemService.UpdateAsync(userId, CampaignId, savedItemId.Value, input);
            if (error is not null)
            {
                dialogErrorMessage = error;
                return;
            }
        }
        else if (itemDialogForUnassigned)
        {
            var (item, createError) = await ItemService.CreateUnassignedAsync(userId, CampaignId, input);
            if (createError is not null)
            {
                dialogErrorMessage = createError;
                return;
            }

            savedItemId = item?.Id;
        }
        else
        {
            if (!HasCharacterSelection)
            {
                dialogErrorMessage = "Please select a character first.";
                return;
            }

            var (characterItem, characterCreateError) = await ItemService.CreateForCharacterAsync(
                userId,
                CampaignId,
                selectedCharacterId!.Value,
                input);

            if (characterCreateError is not null)
            {
                dialogErrorMessage = characterCreateError;
                return;
            }

            savedItemId = characterItem?.Id;
        }

        if (savedItemId.HasValue)
        {
            var imageError = await ApplyPendingItemImageAsync(savedItemId.Value);
            if (imageError is not null)
            {
                dialogErrorMessage = imageError;
                return;
            }
        }

        showItemDialog = false;
        ResetItemImageState();
        await LoadAllDataAsync();

        if (savedItemId.HasValue)
        {
            if (itemDialogForUnassigned)
            {
                selectedUnassignedItemId = savedItemId;
            }
            else
            {
                selectedItemId = savedItemId;
            }
        }

        statusMessage = editingItem ? "Item updated." : "Item created.";
    }

