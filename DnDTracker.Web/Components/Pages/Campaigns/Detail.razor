@page "/campaigns/{CampaignId:guid}"
@rendermode InteractiveServer

@using System.Security.Claims
@using DnDTracker.Web.Models
@using DnDTracker.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms

@attribute [Authorize]

@inject CampaignService CampaignService
@inject CharacterService CharacterService
@inject ItemService ItemService
@inject ItemImageService ItemImageService
@inject SkillService SkillService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@pageTitle</PageTitle>

@if (campaign is null)
{
    <h1>Campaign not found</h1>
    <p>The campaign may have been removed or you do not have access to it.</p>
    <a class="btn btn-secondary" href="campaigns">Back to campaigns</a>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">@campaign.Name</h1>
        <a class="btn btn-secondary" href="campaigns">Back to campaigns</a>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info" role="status">@statusMessage</div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="row g-3">
        <div class="col-lg-3">
            <h2 class="h5">Characters</h2>
            @if (characters.Count == 0)
            {
                <p class="text-muted small">No characters yet.</p>
            }
            else
            {
                <div class="list-group mb-2">
                    @foreach (var character in characters)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action @(selectedCharacterId == character.Id ? "active" : "")"
                                @onclick="() => SelectCharacter(character.Id)">
                            @character.Name
                        </button>
                    }
                </div>
            }
            <div class="d-flex flex-wrap gap-1">
                <button class="btn btn-sm btn-primary" @onclick="ShowCreateCharacterDialog">Add</button>
                <button class="btn btn-sm btn-secondary" disabled="@(!HasCharacterSelection)" @onclick="ShowEditCharacterDialog">Edit</button>
                <button class="btn btn-sm btn-danger" disabled="@(!HasCharacterSelection)" @onclick="ShowDeleteCharacterDialog">Remove</button>
            </div>

            <h2 class="h6 mt-4">Modules</h2>
            <a class="btn btn-sm btn-outline-primary" href="campaigns/@CampaignId/roll-tables" target="_blank" rel="noopener noreferrer">Rollable Tables</a>
        </div>

        <div class="col-lg-5">
            @if (!HasCharacterSelection)
            {
                <p class="text-muted">Select a character to manage skills and items, or use the Unassigned tab.</p>
            }

            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button type="button" class="nav-link @(activeTab == DetailTab.Skills ? "active" : "")" disabled="@(!HasCharacterSelection)" @onclick="() => SetTab(DetailTab.Skills)">Skills</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(activeTab == DetailTab.Items ? "active" : "")" disabled="@(!HasCharacterSelection)" @onclick="() => SetTab(DetailTab.Items)">Items</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(activeTab == DetailTab.Unassigned ? "active" : "")" @onclick="() => SetTab(DetailTab.Unassigned)">Unassigned</button>
                </li>
            </ul>

            @if (activeTab == DetailTab.Skills)
            {
                <h3 class="h6">Skills</h3>
                @if (!HasCharacterSelection)
                {
                    <p class="text-muted small">Select a character first.</p>
                }
                else if (skills.Count == 0)
                {
                    <p class="text-muted small">No skills for this character.</p>
                }
                else
                {
                    <div class="list-group mb-2">
                        @foreach (var skill in skills)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action @(selectedSkillId == skill.Id ? "active" : "")"
                                    @onclick="() => SelectSkill(skill.Id)">
                                @skill.Name
                            </button>
                        }
                    </div>
                }
                <div class="d-flex flex-wrap gap-1">
                    <button class="btn btn-sm btn-primary" disabled="@(!HasCharacterSelection)" @onclick="ShowCreateSkillDialog">Add</button>
                    <button class="btn btn-sm btn-secondary" disabled="@(!HasSkillSelection)" @onclick="ShowEditSkillDialog">Edit</button>
                    <button class="btn btn-sm btn-danger" disabled="@(!HasSkillSelection)" @onclick="ShowDeleteSkillDialog">Remove</button>
                </div>
            }
            else if (activeTab == DetailTab.Items)
            {
                <h3 class="h6">Items</h3>
                @if (!HasCharacterSelection)
                {
                    <p class="text-muted small">Select a character first.</p>
                }
                else if (characterItems.Count == 0)
                {
                    <p class="text-muted small">No items for this character.</p>
                }
                else
                {
                    <div class="list-group mb-2">
                        @foreach (var item in characterItems)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action @(selectedItemId == item.Id ? "active" : "")"
                                    @onclick="() => SelectCharacterItem(item.Id)">
                                @item.Name
                            </button>
                        }
                    </div>
                }
                <div class="d-flex flex-wrap gap-1">
                    <button class="btn btn-sm btn-primary" disabled="@(!HasCharacterSelection)" @onclick="ShowCreateCharacterItemDialog">Add</button>
                    <button class="btn btn-sm btn-secondary" disabled="@(!HasCharacterItemSelection)" @onclick="ShowEditCharacterItemDialog">Edit</button>
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasCharacterItemSelection)" @onclick="ShowCopyItemDialog">Copy</button>
                    <button class="btn btn-sm btn-warning" disabled="@(!HasCharacterItemSelection)" @onclick="UnassignSelectedItem">Unassign</button>
                    <button class="btn btn-sm btn-danger" disabled="@(!HasCharacterItemSelection)" @onclick="ShowDeleteCharacterItemDialog">Remove</button>
                </div>
            }
            else
            {
                <h3 class="h6">Unassigned items</h3>
                @if (unassignedItems.Count == 0)
                {
                    <p class="text-muted small">No unassigned items.</p>
                }
                else
                {
                    <div class="list-group mb-2">
                        @foreach (var item in unassignedItems)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action @(selectedUnassignedItemId == item.Id ? "active" : "")"
                                    @onclick="() => SelectUnassignedItem(item.Id)">
                                @item.Name
                            </button>
                        }
                    </div>
                }
                <div class="d-flex flex-wrap gap-1">
                    <button class="btn btn-sm btn-primary" @onclick="ShowCreateUnassignedItemDialog">Add</button>
                    <button class="btn btn-sm btn-secondary" disabled="@(!HasUnassignedItemSelection)" @onclick="ShowEditUnassignedItemDialog">Edit</button>
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasUnassignedItemSelection)" @onclick="ShowCopyItemDialog">Copy</button>
                    <button class="btn btn-sm btn-outline-primary" disabled="@(!CanAssignItem)" @onclick="ShowAssignDialog">Assign</button>
                    <button class="btn btn-sm btn-danger" disabled="@(!HasUnassignedItemSelection)" @onclick="ShowDeleteUnassignedItemDialog">Remove</button>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <h2 class="h5">Details</h2>
            @if (activeTab == DetailTab.Skills && SelectedSkill is not null)
            {
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@SelectedSkill.Name</dd>
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8 preserve-line-breaks">@DisplayValue(SelectedSkill.Description)</dd>
                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8 preserve-line-breaks">@DisplayValue(SelectedSkill.Notes)</dd>
                </dl>
            }
            else if ((activeTab == DetailTab.Items && SelectedCharacterItem is not null) ||
                     (activeTab == DetailTab.Unassigned && SelectedUnassignedItem is not null))
            {
                var item = activeTab == DetailTab.Items ? SelectedCharacterItem! : SelectedUnassignedItem!;
                <div class="mb-3">
                    @if (HasItemImage(item))
                    {
                        <button type="button" class="btn btn-link p-0 border-0" @onclick="() => ShowLargeImageDialog(item.Id, item.Name)">
                            <img src="@GetItemImageUrl(item.Id)"
                                 alt="@item.Name"
                                 class="img-fluid rounded border"
                                 style="max-height: 180px;" />
                        </button>
                    }
                    else
                    {
                        <div class="text-muted border rounded p-4 text-center small">No image</div>
                    }
                </div>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <label class="btn btn-sm btn-outline-primary mb-0">
                        Choose image
                        <InputFile class="d-none" OnChange="OnDetailsImageSelected" accept=".png,.jpg,.jpeg,.bmp" />
                    </label>
                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasItemImage(item))" @onclick="() => ClearDetailsImage(item.Id)">Clear image</button>
                </div>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@item.Name</dd>
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8 preserve-line-breaks">@DisplayValue(item.Description)</dd>
                    <dt class="col-sm-4">Where found</dt>
                    <dd class="col-sm-8">@DisplayValue(item.WhereFound)</dd>
                    <dt class="col-sm-4">When found</dt>
                    <dd class="col-sm-8">@DisplayValue(item.WhenFound)</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@DisplayValue(item.CurrentStatus)</dd>
                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8 preserve-line-breaks">@DisplayValue(item.Notes)</dd>
                </dl>
            }
            else
            {
                <p class="text-muted small">Select a skill or item to view details.</p>
            }
        </div>
    </div>
}

@if (showLargeImageDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.75);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@largeImageTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseLargeImageDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <img src="@largeImageUrl" alt="@largeImageTitle" class="img-fluid" />
                </div>
            </div>
        </div>
    </div>
}

@if (showCharacterDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@characterDialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseCharacterDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(dialogErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@dialogErrorMessage</div>
                    }
                    <div class="form-floating">
                        <input id="characterName" class="form-control" @bind="characterNameInput" @bind:event="oninput" placeholder="Character name" />
                        <label for="characterName">Character name</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseCharacterDialog">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveCharacter">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showSkillDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@skillDialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseSkillDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(dialogErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@dialogErrorMessage</div>
                    }
                    <div class="form-floating mb-3">
                        <input id="skillName" class="form-control" @bind="skillNameInput" @bind:event="oninput" placeholder="Skill name" />
                        <label for="skillName">Skill name</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="skillDescription">Description</label>
                        <textarea id="skillDescription" class="form-control" rows="2" @bind="skillDescriptionInput"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="skillNotes">Notes</label>
                        <textarea id="skillNotes" class="form-control" rows="3" @bind="skillNotesInput"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseSkillDialog">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveSkill">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showItemDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@itemDialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseItemDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(dialogErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@dialogErrorMessage</div>
                    }
                    <div class="form-floating mb-3">
                        <input id="itemName" class="form-control" @bind="itemNameInput" @bind:event="oninput" placeholder="Item name" />
                        <label for="itemName">Item name</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="itemDescription">Description</label>
                        <input id="itemDescription" class="form-control" @bind="itemDescriptionInput" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="itemWhereFound">Where found</label>
                            <input id="itemWhereFound" class="form-control" @bind="itemWhereFoundInput" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="itemWhenFound">When found</label>
                            <input id="itemWhenFound" class="form-control" @bind="itemWhenFoundInput" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="itemStatus">Current status</label>
                        <input id="itemStatus" class="form-control" @bind="itemStatusInput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="itemNotes">Notes</label>
                        <textarea id="itemNotes" class="form-control" rows="3" @bind="itemNotesInput"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Item image</label>
                        @if (!string.IsNullOrEmpty(itemImagePreviewUrl))
                        {
                            <img src="@itemImagePreviewUrl" alt="Item preview" class="img-fluid rounded border mb-2" style="max-height: 160px;" />
                        }
                        else if (editingItem && HasItemImagePath(editingItemImagePath) && !clearItemImagePending)
                        {
                            <img src="@GetItemImageUrl(GetEditingItemId())" alt="Item preview" class="img-fluid rounded border mb-2" style="max-height: 160px;" />
                        }
                        else
                        {
                            <div class="text-muted border rounded p-3 text-center small mb-2">No image selected</div>
                        }
                        <div class="d-flex flex-wrap gap-2">
                            <label class="btn btn-sm btn-outline-primary mb-0">
                                Choose image
                                <InputFile class="d-none" OnChange="OnDialogImageSelected" accept=".png,.jpg,.jpeg,.bmp" />
                            </label>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="MarkItemImageForClear">Clear image</button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseItemDialog">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveItem">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showCopyDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Copy item</h5>
                    <button type="button" class="btn-close" @onclick="CloseCopyDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(dialogErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@dialogErrorMessage</div>
                    }

                    <p>Where should the copy of '@copySourceItemName' go?</p>

                    <div class="list-group mb-3">
                        <button type="button"
                                class="list-group-item list-group-item-action @(copyToUnassigned ? "active" : "")"
                                @onclick="SelectCopyToUnassigned">
                            Unassigned items
                        </button>
                    </div>

                    @if (characters.Count == 0)
                    {
                        <p class="text-muted small">No characters in this campaign. The copy can only go to unassigned items.</p>
                    }
                    else
                    {
                        <p class="small text-muted mb-2">Or assign the copy to a character:</p>
                        <div class="list-group">
                            @foreach (var character in characters)
                            {
                                <button type="button"
                                        class="list-group-item list-group-item-action @(copyTargetCharacterId == character.Id ? "active" : "")"
                                        @onclick="() => SelectCopyToCharacter(character.Id)">
                                    @character.Name
                                </button>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseCopyDialog">Cancel</button>
                    <button type="button" class="btn btn-primary" disabled="@(!CanConfirmCopy)" @onclick="ConfirmCopyItem">Copy</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showAssignDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Assign to character</h5>
                    <button type="button" class="btn-close" @onclick="CloseAssignDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(dialogErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@dialogErrorMessage</div>
                    }

                    <p>Select a character to carry '@SelectedUnassignedItem?.Name':</p>

                    @if (characters.Count == 0)
                    {
                        <p class="text-muted">No characters in this campaign. Add a character first.</p>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var character in characters)
                            {
                                <button type="button"
                                        class="list-group-item list-group-item-action @(assignTargetCharacterId == character.Id ? "active" : "")"
                                        @onclick="() => assignTargetCharacterId = character.Id">
                                    @character.Name
                                </button>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAssignDialog">Cancel</button>
                    <button type="button" class="btn btn-primary" disabled="@(!assignTargetCharacterId.HasValue)" @onclick="ConfirmAssign">Assign</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@deleteDialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>@deleteDialogMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteDialog">No</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Yes</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid CampaignId { get; set; }

    private enum DetailTab
    {
        Skills,
        Items,
        Unassigned
    }

    private enum DeleteTarget
    {
        Character,
        CharacterItem,
        UnassignedItem,
        Skill
    }

    private Campaign? campaign;
    private List<Character> characters = [];
    private List<Skill> skills = [];
    private List<Item> characterItems = [];
    private List<Item> unassignedItems = [];

    private string? userId;
    private string pageTitle = "Campaign";

    private Guid? selectedCharacterId;
    private Guid? selectedItemId;
    private Guid? selectedSkillId;
    private Guid? selectedUnassignedItemId;
    private DetailTab activeTab = DetailTab.Skills;

    private string? statusMessage;
    private string? errorMessage;
    private string? dialogErrorMessage;

    private bool showCharacterDialog;
    private bool editingCharacter;
    private string characterDialogTitle = "";
    private string characterNameInput = "";

    private bool showSkillDialog;
    private bool editingSkill;
    private string skillDialogTitle = "";
    private string skillNameInput = "";
    private string skillDescriptionInput = "";
    private string skillNotesInput = "";

    private bool showItemDialog;
    private bool editingItem;
    private bool itemDialogForUnassigned;
    private string itemDialogTitle = "";
    private string itemNameInput = "";
    private string itemDescriptionInput = "";
    private string itemWhereFoundInput = "";
    private string itemWhenFoundInput = "";
    private string itemStatusInput = "";
    private string itemNotesInput = "";
    private IBrowserFile? pendingImageFile;
    private string? itemImagePreviewUrl;
    private bool clearItemImagePending;
    private string editingItemImagePath = "";
    private long imageCacheVersion;

    private bool showLargeImageDialog;
    private string largeImageUrl = "";
    private string largeImageTitle = "";

    private bool showAssignDialog;
    private Guid? assignTargetCharacterId;

    private bool showCopyDialog;
    private Guid? copySourceItemId;
    private string copySourceItemName = "";
    private bool copyToUnassigned;
    private Guid? copyTargetCharacterId;

    private bool showDeleteDialog;
    private DeleteTarget deleteTarget;
    private string deleteDialogTitle = "";
    private string deleteDialogMessage = "";

    private bool HasCharacterSelection => selectedCharacterId.HasValue;
    private bool HasSkillSelection => selectedSkillId.HasValue;
    private bool HasCharacterItemSelection => selectedItemId.HasValue;
    private bool HasUnassignedItemSelection => selectedUnassignedItemId.HasValue;
    private bool CanAssignItem => HasUnassignedItemSelection && characters.Count > 0;
    private bool CanConfirmCopy => copyToUnassigned || copyTargetCharacterId.HasValue;

    private Skill? SelectedSkill => skills.FirstOrDefault(s => s.Id == selectedSkillId);
    private Item? SelectedCharacterItem => characterItems.FirstOrDefault(i => i.Id == selectedItemId);
    private Item? SelectedUnassignedItem => unassignedItems.FirstOrDefault(i => i.Id == selectedUnassignedItemId);

    protected override async Task OnParametersSetAsync()
    {
        userId = await GetUserIdAsync();
        if (userId is null)
        {
            campaign = null;
            return;
        }

        campaign = await CampaignService.GetCampaignAsync(userId, CampaignId);
        pageTitle = campaign?.Name ?? "Campaign not found";

        if (campaign is not null)
        {
            await LoadAllDataAsync();
        }
    }

    private async Task LoadAllDataAsync()
    {
        if (userId is null)
        {
            return;
        }

        characters = await CharacterService.GetByCampaignAsync(userId, CampaignId);
        unassignedItems = await ItemService.GetUnassignedAsync(userId, CampaignId);

        if (selectedCharacterId.HasValue &&
            characters.All(c => c.Id != selectedCharacterId.Value))
        {
            selectedCharacterId = characters.FirstOrDefault()?.Id;
        }

        await LoadCharacterDataAsync();
    }

    private async Task LoadCharacterDataAsync()
    {
        selectedItemId = null;
        selectedSkillId = null;
        skills = [];
        characterItems = [];

        if (!HasCharacterSelection || userId is null)
        {
            return;
        }

        skills = await SkillService.GetByCharacterAsync(userId, CampaignId, selectedCharacterId!.Value);
        characterItems = await ItemService.GetByCharacterAsync(userId, CampaignId, selectedCharacterId.Value);
    }

    private async Task SelectCharacter(Guid characterId)
    {
        selectedCharacterId = characterId;
