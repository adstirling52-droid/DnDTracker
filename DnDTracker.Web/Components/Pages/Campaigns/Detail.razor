    private async Task ConfirmCopyItem()
    {
        if (userId is null || !copySourceItemId.HasValue || !CanConfirmCopy)
        {
            return;
        }

        var targetCharacterId = copyToUnassigned ? null : copyTargetCharacterId;
        var (copy, error) = await ItemService.CopyAsync(
            userId,
            CampaignId,
            copySourceItemId.Value,
            targetCharacterId);

        if (error is not null)
        {
            dialogErrorMessage = error;
            return;
        }

        showCopyDialog = false;
        copySourceItemId = null;
        copySourceItemName = "";
        copyToUnassigned = false;
        copyTargetCharacterId = null;

        await LoadAllDataAsync();

        if (copy is null)
        {
            return;
        }

        if (copy.CharacterId.HasValue)
        {
            selectedCharacterId = copy.CharacterId;
            activeTab = DetailTab.Items;
            selectedItemId = copy.Id;
            selectedUnassignedItemId = null;
        }
        else
        {
            activeTab = DetailTab.Unassigned;
            selectedUnassignedItemId = copy.Id;
            selectedItemId = null;
        }

        imageCacheVersion++;
        statusMessage = $"Item copied as '{copy.Name}'.";
    }

