    private static async Task<string> CreatePreviewUrlAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(ItemImageService.MaxFileSizeBytes);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        var base64 = Convert.ToBase64String(memoryStream.ToArray());
        var contentType = string.IsNullOrWhiteSpace(file.ContentType) ? "image/png" : file.ContentType;
        return $"data:{contentType};base64,{base64}";
    }

    private static string DisplayValue(string value) =>
