    private async Task ConfirmDelete()
    {
        if (userId is null)
        {
            return;
        }

        var deleted = deleteTarget switch
        {
            DeleteTarget.Character => await CharacterService.DeleteAsync(
                userId, CampaignId, selectedCharacterId!.Value),
            DeleteTarget.CharacterItem => await ItemService.DeleteAsync(
                userId, CampaignId, selectedItemId!.Value),
            DeleteTarget.UnassignedItem => await ItemService.DeleteAsync(
                userId, CampaignId, selectedUnassignedItemId!.Value),
            DeleteTarget.Skill => await SkillService.DeleteAsync(
                userId, CampaignId, selectedCharacterId!.Value, selectedSkillId!.Value),
            _ => false
        };

        showDeleteDialog = false;

        if (!deleted)
        {
            errorMessage = "Unable to remove the selected item.";
            return;
        }

        if (deleteTarget == DeleteTarget.Character)
        {
            selectedCharacterId = null;
        }

        await LoadAllDataAsync();
        selectedCharacterId ??= characters.FirstOrDefault()?.Id;
        statusMessage = "Removed successfully.";
    }

