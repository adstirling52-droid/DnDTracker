    private async Task OnDialogImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > ItemImageService.MaxFileSizeBytes)
        {
            dialogErrorMessage = "Image must be 5 MB or smaller.";
            return;
        }

        if (!ItemImageService.IsAllowedExtension(Path.GetExtension(file.Name)))
        {
            dialogErrorMessage = "Only PNG, JPG, JPEG, and BMP images are supported.";
            return;
        }

        pendingImageFile = file;
        clearItemImagePending = false;
        itemImagePreviewUrl = await CreatePreviewUrlAsync(file);
        dialogErrorMessage = null;
    }

    private void MarkItemImageForClear()
    {
        pendingImageFile = null;
        itemImagePreviewUrl = null;
        clearItemImagePending = true;
    }

    private async Task<string?> ApplyPendingItemImageAsync(Guid itemId)
    {
        if (userId is null)
        {
            return "Unable to determine the current user.";
        }

        if (clearItemImagePending)
        {
            var clearError = await ItemImageService.ClearForItemAsync(userId, CampaignId, itemId);
            if (clearError is null)
            {
                imageCacheVersion++;
            }

            return clearError;
        }

        if (pendingImageFile is null)
        {
            return null;
        }

        await using var stream = pendingImageFile.OpenReadStream(ItemImageService.MaxFileSizeBytes);
        var (_, saveError) = await ItemImageService.SaveForItemAsync(
            userId,
            CampaignId,
            itemId,
            stream,
            pendingImageFile.Name);

        if (saveError is null)
        {
            imageCacheVersion++;
        }

        return saveError;
    }

    private async Task OnDetailsImageSelected(InputFileChangeEventArgs e)
    {
        if (userId is null)
        {
            return;
        }

        var itemId = GetSelectedDetailsItemId();
        if (!itemId.HasValue)
        {
            errorMessage = "Please select an item first.";
            return;
        }

        var file = e.File;
        if (file.Size > ItemImageService.MaxFileSizeBytes)
        {
            errorMessage = "Image must be 5 MB or smaller.";
            return;
        }

        if (!ItemImageService.IsAllowedExtension(Path.GetExtension(file.Name)))
        {
            errorMessage = "Only PNG, JPG, JPEG, and BMP images are supported.";
            return;
        }

        await using var stream = file.OpenReadStream(ItemImageService.MaxFileSizeBytes);
        var (_, saveError) = await ItemImageService.SaveForItemAsync(
            userId,
            CampaignId,
            itemId.Value,
            stream,
            file.Name);

        if (saveError is not null)
        {
            errorMessage = saveError;
            return;
        }

        imageCacheVersion++;
        await LoadAllDataAsync();
        statusMessage = "Item image updated.";
    }

    private async Task ClearDetailsImage(Guid itemId)
    {
        if (userId is null)
        {
            return;
        }

        var clearError = await ItemImageService.ClearForItemAsync(userId, CampaignId, itemId);
        if (clearError is not null)
        {
            errorMessage = clearError;
            return;
        }

        imageCacheVersion++;
        await LoadAllDataAsync();
        statusMessage = "Item image cleared.";
    }

